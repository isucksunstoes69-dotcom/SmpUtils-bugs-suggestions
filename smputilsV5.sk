on left click:
    if "%player's tool%" contains "spear":
        if {spear.lunge.cd::%player's uuid%} is set:
            cancel event
            set velocity of player to new vector 0, 0, 0
            stop
        # --- your lunge code here ---
        set {spear.lunge.cd::%player's uuid%} to true
        wait ("%{LungeSwapCooldown}% seconds") parsed as timespan
        delete {spear.lunge.cd::%player's uuid%}



#█▄▄ █▀▀ █▀▄   █▄▄ █▀█ █▀▄▀█ █▄▄   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
