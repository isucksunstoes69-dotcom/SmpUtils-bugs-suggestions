		set {ban::fireresistance2} to "&cDisabled"
	if {ban::healing2} is not set: 
		set {ban::healing2} to "&cDisabled"
	if {ban::harming2} is not set: 
		set {ban::harming2} to "&cDisabled"
	if {ban::jump2} is not set: 
		set {ban::jump2} to "&cDisabled"
	if {ban::nightvision2} is not set: 
		set {ban::nightvision2} to "&cDisabled"
	if {ban::invisibility2} is not set: 
		set {ban::invisibility2} to "&cDisabled"
	if {ban::waterbreathing2} is not set: 
		set {ban::waterbreathing2} to "&cDisabled"
	if {ban::slowfalling2} is not set: 
		set {ban::slowfalling2} to "&cDisabled"
	if {ban::turtlemaster2} is not set: 
		set {ban::turtlemaster2} to "&cDisabled"
	if {ban::poison2} is not set: 
		set {ban::poison2} to "&cDisabled"
	if {ban::weakness2} is not set: 
		set {ban::weakness2} to "&cDisabled"
	if {ban::slowness2} is not set: 
		set {ban::slowness2} to "&cDisabled"
	if {LungeSwapCooldown} is not set:
		set {LungeSwapCooldown} to 5
	if {banBedBomingOption} is not set:
		set {banBedBomingOption} to "&cDisabled"
	if {FasterHappyGhastOption} is not set:
		set {FasterHappyGhastOption} to "&aEnabled"
	if {gapCooldown} is not set:
		set {gapCooldown} to 0
	if {SpecDeathOption} is not set:
		set {SpecDeathOption} to "&cDisabled"


	

	
	

