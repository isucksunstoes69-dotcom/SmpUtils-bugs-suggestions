on load:
	send "dependecies skript skbee skreflect skript-particle (MAYBE)" to player
	if {NethBanOption} is not set:
		set {NethBanOption} to "&cDisabled"
	if {PvpBanOption} is not set:
		set {PvpBanOption} to "&cDisabled"
	if {PearlBanOption} is not set:
		set {PearlBanOption} to "&cDisabled"
	if {banPotionOption} is not set:
		set {banPotionOption} to "&cDisabled"
	if {maceOneTimeCraftOption} is not set:
		set {maceOneTimeCraftOption} to "&cDisabled"
	if {banMaceOption} is not set:
		set {banMaceOption} to "&cDisabled"
	if {maceStunsShieldOption} is not set:
		set {maceStunsShieldOption} to "&cDisabled"
	if {banPearlOption} is not set:
		set {banPearlOption} to "&cDisabled"
	if {lifestealPearlOption} is not set:
		set {lifestealPearlOption} to "&cDisabled"
	if {allowNetherOption} is not set:
		set {allowNetherOption} to "&aEnabled"
	if {allowEndOption} is not set:
		set {allowEndOption} to "&aEnabled"
	if {maceCooldown} is not set:
		set {maceCooldown} to 5
	if {sharpnessLevel} is not set:
		set {sharpnessLevel} to 5
	if {protectionLevel} is not set:
		set {protectionLevel} to 4
	if {banCrystalPvpOption} is not set:
		set {banCrystalPvpOption} to "&cDisabled"
	if {banTier2PotionsOption} is not set:
		set {banTier2PotionsOption} to "&cDisabled"
	if {banStrengthPotionsOption} is not set:
		set {banStrengthPotionsOption} to "&cDisabled"
	if {ban::strength} is not set:
		set {ban::strength} to "&cDisabled"
	if {ban::swiftness} is not set:
		set {ban::swiftness} to "&cDisabled"
	if {ban::regeneration} is not set:
		set {ban::regeneration} to "&cDisabled"
	if {ban::luck} is not set:
		set {ban::luck} to "&cDisabled"
	if {ban::fireresistance} is not set:
		set {ban::fireresistance} to "&cDisabled"
	if {ban::healing} is not set:
		set {ban::healing} to "&cDisabled"
	if {ban::harming} is not set:
		set {ban::harming} to "&cDisabled"
	if {ban::jump} is not set:
		set {ban::jump} to "&cDisabled"
	if {ban::nightvision} is not set:
		set {ban::nightvision} to "&cDisabled"
	if {ban::invisibility} is not set:
		set {ban::invisibility} to "&cDisabled"
	if {ban::waterbreathing} is not set:
		set {ban::waterbreathing} to "&cDisabled"
	if {ban::slowfalling} is not set:
		set {ban::slowfalling} to "&cDisabled"
	if {ban::turtlemaster} is not set:
		set {ban::turtlemaster} to "&cDisabled"
	if {ban::poison} is not set:
		set {ban::poison} to "&cDisabled"
	if {ban::weakness} is not set:
		set {ban::weakness} to "&cDisabled"
	if {ban::slowness} is not set:
		set {ban::slowness} to "&cDisabled"
	if {ban::all} is not set:
		set {ban::all} to "&cDisabled"
	if {maceCrafted} is not set:
		set {maceCrafted} to false
	if {healthIndicatorOption} is not set:
		set {healthIndicatorOption} to "&cDisabled"
	if {e-gapCooldown} is not set:
		set {e-gapCooldown} to 0
	if {pearlCooldown} is not set:
		set {pearlCooldown} to 0
	if {windChargeCooldown} is not set:
		set {windChargeCooldown} to 0.5
	if {nakedProtectionOption} is not set:
		set {nakedProtectionOption} to "&cDisabled"
	if {shieldCooldown} is not set:
		set {shieldCooldown} to 0.5
	if {banVillagerKillingOption} is not set:
		set {banVillagerKillingOption} to "&cDisabled"
	if {banMinecartOption} is not set:
		set {banMinecartOption} to "&cDisabled"
	if {ritualRadiusOption} is not set:
		set {ritualRadiusOption} to 5
	if {ritualDurationOption} is not set:
		set {ritualDurationOption} to 1
	if {ritualColorOption} is not set:
		set {ritualColorOption} to "&9Blue"
	if {ban::strength2} is not set:
		set {ban::strength2} to "&cDisabled"
	if {ban::swiftness2} is not set:
		set {ban::swiftness2} to "&cDisabled"
	if {ban::regeneration2} is not set: 
		set {ban::regeneration2} to "&cDisabled"
	if {ban::luck2} is not set: 
		set {ban::luck2} to "&cDisabled"
