command /ritual:
    permission: op
    trigger:
        if player's tool is not air:
            set {_x} to rounded player's x-coordinate
            set {_y} to rounded player's y-coordinate
            set {_z} to rounded player's z-coordinate
            set {_item} to player's tool
            set {_loc} to location of player ~ vector(0, 1, 0)
            set pitch of {_loc} to 0
            set {_name} to smallcaps("%{_item}%")
            play sound "entity.wither.spawn" to all players
            broadcast "&6&l%player% &5has started a ritual at &6&l(%{_x}%, %{_y}%, %{_z}%) &5in"
            broadcast "&a%world of player% &5for &6%{_name}%"
            spawn text display at location of player's eyes
            set {_displayName} to last spawned entity
            spawn text display at location 0.3 meters below player's eyes
            set {_displayTime} to last spawned entity
            set text of {_displayName} to "&d%{_name}%"
            set billboard of {_displayName} to center
            set billboard of {_displayTime} to center
            set {_seconds} to {ritualDurationOption} * 60
            set {_tickblabla} to 0
            spawn item display at {_loc}
            set {_ritualItem} to last spawned item display
            set item of {_ritualItem} to {_item}
            set display scale of {_ritualItem} to vector(0.5, 0.5, 0.5)
            set glowing of {_ritualItem} to true
            
            # Create boss bar for ritual
            set {_totalSeconds} to {_seconds}
            set {_ritualBar} to boss bar with id "ritual-bar" with title "&dRitual: %{_name}% &e(%{_x}%, %{_y}%, %{_z}%) &f- &e%{_seconds}%s" with color purple with progress 100
            add all players to {_ritualBar}
            
            while {_seconds} > 0:
                if {_tickblabla} mod 2 = 0:
                    set {_minutesLeft} to floor({_seconds} / 60)
                    set {_secondsLeft} to {_seconds} mod 60
                    if {_secondsLeft} < 10:
                        set {_displayTimeText} to "%{_minutesLeft}%:0%{_secondsLeft}%"
                    else:
                        set {_displayTimeText} to "%{_minutesLeft}%:%{_secondsLeft}%"
                    set text of {_displayTime} to "&e%{_displayTimeText}%"
                    
                    # Update boss bar
                    set {_progress} to ({_seconds} / {_totalSeconds}) * 100
                    set {_ritualBar} to boss bar with id "ritual-bar"
                    set bar title of {_ritualBar} to "&dRitual: %{_name}% &e(%{_x}%, %{_y}%, %{_z}%) &f- &e%{_seconds}%s"
                    set bar progress of {_ritualBar} to {_progress}
                    
                    # Change bar color based on time remaining
                    if {_seconds} > {_totalSeconds} / 2:
                        set bar color of {_ritualBar} to purple
                    else if {_seconds} > {_totalSeconds} / 4:
                        set bar color of {_ritualBar} to blue
                    else if {_seconds} > 10:
                        set bar color of {_ritualBar} to yellow
                    else:
                        set bar color of {_ritualBar} to red
                    
                    remove 1 from {_seconds}
                
                set {_circle} to a circle of radius {ritualRadiusOption} / 2
                if {ritualColorOption} is "&9Blue":
                    set particle of {_circle} to dust particle using dustOption(blue, 2)
                else if {ritualColorOption} is "&eYellow":
                    set particle of {_circle} to dust particle using dustOption(yellow, 2)
                else if {ritualColorOption} is "&bAqua":
                    set particle of {_circle} to dust particle using dustOption(aqua, 2)
                else if {ritualColorOption} is "&dFuchsia":
                    set particle of {_circle} to dust particle using dustOption(magenta, 2)
                else if {ritualColorOption} is "&aLime":
                    set particle of {_circle} to dust particle using dustOption(lime, 2)
                else if {ritualColorOption} is "&6Orange":
                    set particle of {_circle} to dust particle using dustOption(orange, 2)
                else if {ritualColorOption} is "&5Purple":
                    set particle of {_circle} to dust particle using dustOption(purple, 2)
                else if {ritualColorOption} is "&fWhite":
                    set particle of {_circle} to dust particle using dustOption(white, 2)
                else if {ritualColorOption} is "&0Black":
                    set particle of {_circle} to dust particle using dustOption(black, 2)
                else if {ritualColorOption} is "&7Gray":
                    set particle of {_circle} to dust particle using dustOption(gray, 2)
                else if {ritualColorOption} is "&cRed":
                    set particle of {_circle} to dust particle using dustOption(red, 2)
                else if {ritualColorOption} is "&2Green":
                    set particle of {_circle} to dust particle using dustOption(green, 2)
                draw shape {_circle} at {_loc}
                set particle of {_circle} to enchant particle
                draw shape {_circle} at {_loc}
                add 1 to {_tickblabla}
                loop 20 times:
                    rotate {_ritualItem} around y axis by 2.5
                    wait 1 tick
            
            strike lightning at {_loc}
            broadcast "&dThe Ritual for &6%{_name}% &dhas ended!"
            delete boss bar with id "ritual-bar"
            kill {_displayName}
            kill {_displayTime}
            kill {_ritualItem}
            wait 20 ticks
            drop {_item} at {_loc}
        else:
            send "&cYou're not holding any item!" to player

