on inventory click:
	if name of player's current inventory is "          &8ʀɪᴛᴜᴀʟ sᴇᴛᴛɪɴɢs":
		cancel event
		if player has permission "op":
			if index of event-slot is 1:
				if click action is left mouse button:
					add 1 to {ritualRadiusOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
				else if click action is left mouse button with shift:
					add 10 to {ritualRadiusOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
				else if click action is right mouse button:
					if {ritualRadiusOption} > 1:
						remove 1 from {ritualRadiusOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
				else if click action is right mouse button with shift:
					if {ritualRadiusOption} > 10:
						remove 10 from {ritualRadiusOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
			else if index of event-slot is 2:
				if click action is left mouse button:
					add 1 to {ritualDurationOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
				else if click action is left mouse button with shift:
					add 10 to {ritualDurationOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
				else if click action is right mouse button:
					if {ritualDurationOption} > 1:
						remove 1 from {ritualDurationOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
				else if click action is right mouse button with shift:
					if {ritualDurationOption} > 10:
						remove 10 from {ritualDurationOption}
					RitualOptions(player)
					play sound "block.comparator.click" to player
			else if index of event-slot is 3:
				if click action is left mouse button:
					if {ritualColorOption} is "&9Blue":
						set {ritualColorOption} to "&eYellow"
					else if {ritualColorOption} is "&eYellow":
						set {ritualColorOption} to "&bAqua"
					else if {ritualColorOption} is "&bAqua":
						set {ritualColorOption} to "&dFuchsia"
					else if {ritualColorOption} is "&dFuchsia":
						set {ritualColorOption} to "&aLime"
					else if {ritualColorOption} is "&aLime":
						set {ritualColorOption} to "&6Orange"
					else if {ritualColorOption} is "&6Orange":
						set {ritualColorOption} to "&5Purple"
					else if {ritualColorOption} is "&5Purple":
						set {ritualColorOption} to "&fWhite"
					else if {ritualColorOption} is "&fWhite":
						set {ritualColorOption} to "&0Black"
					else if {ritualColorOption} is "&0Black":
						set {ritualColorOption} to "&7Gray"
					else if {ritualColorOption} is "&7Gray":
						set {ritualColorOption} to "&cRed"
					else if {ritualColorOption} is "&cRed":
						set {ritualColorOption} to "&2Green"
					else if {ritualColorOption} is "&2Green":
						set {ritualColorOption} to "&9Blue"
					RitualOptions(player)
					play sound "block.comparator.click" to player


# █▀▄▀█ ▄▀█ █▀▀ █▀▀   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# █░▀░█ █▀█ █▄▄ ██▄   █▄█ █▀▀ ░█░ █ █▄█ █░▀█    

on craft:
	if event-item is mace:
		if {maceOneTimeCraftOption} is "&aEnabled":
			if {maceCrafted} is true:
				cancel event
				send "&cThe Mace has already been crafted!"
			else if {maceCrafted} is false:
				set {maceCrafted} to true
on craft:
	if event-item is mace:
		if {banMaceOption} is "&aEnabled":
			cancel event
			send "&cMaces are banned on this server!"
every 40 ticks:
	if {banMaceOption} is "&aEnabled":
		loop all players:
			if inventory of loop-player contains mace:
				remove all mace from loop-player
				send "&cMaces are banned on this server!" to loop-player
on pickup:
	if event-item is mace:
		if {banMaceOption} is "&aEnabled":
			cancel event
			send "&cMaces are banned on this server!" to player
on damage:
	if attacker's tool is mace:
		if {banMaceOption} is "&aEnabled":
			cancel event
			remove all mace from attacker
			send "&cMaces are banned on this server!" to attacker
on damage:
	if attacker's tool is mace:
		if victim is blocking:
			if {maceStunsShieldOption} is "&aEnabled":
				if victim's offhand tool is shield:
					set the cooldown of shield for victim to {shieldCooldown} * 20 ticks
					set {_shield} to victim's offhand tool
					set victim's offhand tool to air
					wait 1 tick
					set victim's offhand tool to {_shield}
				if victim's tool is shield:
					set the cooldown of shield for victim to {shieldCooldown} * 20 ticks
					set {_shield} to victim's tool
					set victim's tool to air
					wait 1 tick
					set victim's tool to {_shield}


# █▀█ █▀▀ ▄▀█ █▀█ █░░   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# █▀▀ ██▄ █▀█ █▀▄ █▄▄   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

on rightclick:
	if {banPearlOption} is "&aEnabled":
		if player's tool is an ender pearl:
			cancel event
			send "&cUsing ender pearls is not allowed!" to player
on teleport:
	if teleport cause is ender pearl:
		if {lifestealPearlOption} is "&aEnabled":
			cancel event
			send "&cUsing ender pearls is not allowed!" to player

# █▄▄ ▄▀█ █▄░█   █▀▀ █▀█ █▄█ █▀ ▀█▀ ▄▀█ █░░   █▀█ █░█ █▀█   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# █▄█ █▀█ █░▀█   █░▀█ █▀▄ ░█░ ▄█ ░█░ █▀█ █▄▄   █▀▀ ▀▄▀ █▀▀   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

on explosion:
	if event-entity is end crystal:
		if {banCrystalPvpOption} is "&aEnabled":
			cancel event
on damage:
	if attacker is end crystal:
		if {banCrystalPvpOption} = "&aEnabled":
			cancel event
on right click:
	if {banCrystalPvpOption} = "&aEnabled":
		if world of event-block contains "world" or "world_the_end":
			if event-block is respawn anchor:
				if player's tool is glowstone:
					cancel event

# █▄▄ ▄▀█ █▄░█   ▀█▀ █ █▀▀ █▀█   ▀█   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█ █▀   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# █▄█ █▀█ █░▀█   ░█░ █ ██▄ █▀▄   █▄   █▀▀ █▄█ ░█░ █ █▄█ █░▀█ ▄█   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

on entity potion effect modification:
	if {banTier2PotionsOption} is "&aEnabled":
		set {_potion} to event-potion effect
		if "%{_potion}%" contains "tier 2":
			send "&cYou can't use Tier 2 potions on this server!" to player
			cancel event

on inventory click:
	if type of player's current inventory is a brewing stand inventory:
		if {banTier2PotionsOption} is "&aEnabled":
			if any:
				click action is lmb
				click action is rmb
			then:
				if player's cursor slot is glowstone dust:
					cancel event
					send "&cYou can't use Tier 2 potions on this server!" to player
			if click action is swap offhand:
				if player's offhand item is glowstone dust:
					cancel event
					send "&cYou can't use Tier 2 potions on this server!" to player
			if click action is number key:
				if player's inventory.getItem(event.getHotbarButton()) is glowstone dust:
					cancel event
					send "&cYou can't use Tier 2 potions on this server!" to player
	if type of player's current inventory is a brewing stand inventory:
		if {banTier2PotionsOption} is "&aEnabled":
			if any:
				click action is shift+lmb
				click action is shift+rmb
			then:
				if event-item is glowstone dust:
					cancel event
					send "&cYou can't use Tier 2 potions on this server!" to player


# █▄░█ ▄▀█ █▄▀ █▀▀ █▀▄   █▄▀ █ █░░ █░░ █ █▄░█ █▀▀   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# █░▀█ █▀█ █░█ ██▄ █▄▀   █░█ █ █▄▄ █▄▄ █ █░▀█ █▄█   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

on damage:
	if attacker is player:
		if victim is player:
			if victim is not attacker:
				if {nakedProtectionOption} is "&aEnabled":
					if helmet of victim is air:
						if chestplate of victim is air:
							if leggings of victim is air:
								if boots of victim is air:
									cancel event
									send "&cNaked killing is not allowed!" to attacker

# █▀ █░█ █ █▀▀ █░░ █▀▄   █▀▀ █▀█ █▀█ █░░ █▀▄ █▀█ █░█░█ █▄░█   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# ▄█ █▀█ █ ██▄ █▄▄ █▄▀   █▄▄ █▄█ █▄█ █▄▄ █▄▀ █▄█ ▀▄▀▄▀ █░▀█   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

on damage:
	if victim is blocking:
		if "%type of attacker's tool%" contains "axe":
			wait 1 tick
			set the cooldown of shield for victim to {shieldCooldown} * 20 ticks

# █▀▀ ▄▄ █▀▀ ▄▀█ █▀█   █▀▀ █▀█ █▀█ █░░ █▀▄ █▀█ █░█░█ █▄░█   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# ██▄ ░░ █▄█ █▀█ █▀▀   █▄▄ █▄█ █▄█ █▄▄ █▄▀ █▄█ ▀▄▀▄▀ █░▀█   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

on consume:
	if event-item is enchanted golden apple:
		if item cooldown of enchanted golden apple for player > 1 tick:
			cancel event
			stop
		wait 2 tick
		set item cooldown of enchanted golden apple for player to {e-gapCooldown} * 20 ticks

# █▀ █░█ ▄▀█ █▀█ █▀█ █▄░█ █▀▀ █▀ █▀   ▄▀█ █▄░█ █▀▄   █▀█ █▀█ █▀█ ▀█▀   █░░ █ █▀▄▀█ █ ▀█▀   █▀█ █▀█ ▀█▀ █ █▀█ █▄░█
# ▄█ █▀█ █▀█ █▀▄ █▀▀ █░▀█ ██▄ ▄█ ▄█   █▀█ █░▀█ █▄▀   █▀▀ █▀▄ █▄█ ░█░   █▄▄ █ █░▀░█ █ ░█░   █▄█ █▀▀ ░█░ █ █▄█ █░▀█

every 1 second:
	loop all players:
		loop all items in loop-player's inventory:
			if level of sharpness on loop-item > {sharpnessLevel}:
				if {sharpnessLevel} is 0:
					enchant loop-item with sharpness 0
				else if {sharpnessLevel} is 1:
					enchant loop-item with sharpness 1
				else if {sharpnessLevel} is 2:
					enchant loop-item with sharpness 2
				else if {sharpnessLevel} is 3:
					enchant loop-item with sharpness 3
				else if {sharpnessLevel} is 4:
					enchant loop-item with sharpness 4
				else if {sharpnessLevel} is 5:
					enchant loop-item with sharpness 5
			if level of protection on loop-item > {protectionLevel}:
				if {protectionLevel} is 0:
					enchant loop-item with protection 0
				else if {protectionLevel} is 1:
					enchant loop-item with protection 1
				else if {protectionLevel} is 2:
					enchant loop-item with protection 2
				else if {protectionLevel} is 3:
					enchant loop-item with protection 3
				else if {protectionLevel} is 4:
					enchant loop-item with protection 4

