import:
	org.bukkit.event.inventory.PrepareAnvilEvent
	org.bukkit.event.inventory.PrepareSmithingEvent
	org.bukkit.event.inventory.InventoryClickEvent
	org.bukkit.inventory.SmithingInventory

on PrepareAnvilEvent:
	if {NethBanOption} is "&aEnabled":
		set {_item} to event.getInventory().getFirstItem()
		if {_item} is set:
			if {_item} is netherite helmet, netherite chestplate, netherite leggings, netherite boots, netherite sword, netherite axe, netherite pickaxe, netherite shovel or netherite hoe:
				event.setResult(air)

on PrepareSmithingEvent:
	if {NethBanOption} is "&aEnabled":
		set {_result} to event.getInventory().getResult()
		if {_result} is set:
			if {_result} is netherite helmet, netherite chestplate, netherite leggings, netherite boots, netherite sword, netherite axe, netherite pickaxe, netherite shovel or netherite hoe:
				event.setResult(air)

